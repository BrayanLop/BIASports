// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum PickResult {
  PENDING
  WON
  LOST
  VOID
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  username       String    @unique
  name           String?
  image          String?
  bio            String?
  hashedPassword String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  role           Role      @default(USER)
  emailVerified  DateTime?

  accounts  Account[]
  sessions  Session[]
  picks     Pick[]
  comments  Comment[]
  likes     Like[]
  stats     UserStats?

  following Follow[] @relation("Follower")
  followers Follow[] @relation("Following")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("follows")
}

model Sport {
  id      String @id @default(cuid())
  name    String
  slug    String @unique
  icon    String

  leagues League[]
  matches Match[]
  picks   Pick[]

  @@map("sports")
}

model League {
  id      String  @id @default(cuid())
  name    String
  sportId String
  country String?
  logo    String?

  sport   Sport   @relation(fields: [sportId], references: [id])
  matches Match[]

  @@map("leagues")
}

model Match {
  id         String    @id @default(cuid())
  homeTeam   String
  awayTeam   String
  homeScore  Int?
  awayScore  Int?
  leagueId   String
  sportId    String
  matchDate  DateTime
  status     String    @default("SCHEDULED")
  externalId String?   @unique

  league League @relation(fields: [leagueId], references: [id])
  sport  Sport  @relation(fields: [sportId], references: [id])
  picks  Pick[]

  @@map("matches")
}

model Pick {
  id        String     @id @default(cuid())
  userId    String
  matchId   String
  sportId   String
  market    String
  odds      Float
  stake     Int        @default(1)
  result    PickResult @default(PENDING)
  comment   String?    @db.Text
  isPublic  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  match    Match     @relation(fields: [matchId], references: [id])
  sport    Sport     @relation(fields: [sportId], references: [id])
  comments Comment[]
  likes    Like[]

  @@map("picks")
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  userId    String
  pickId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  pick Pick @relation(fields: [pickId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  pickId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  pick Pick @relation(fields: [pickId], references: [id], onDelete: Cascade)

  @@unique([userId, pickId])
  @@map("likes")
}

model UserStats {
  id            String   @id @default(cuid())
  userId        String   @unique
  totalPicks    Int      @default(0)
  wonPicks      Int      @default(0)
  lostPicks     Int      @default(0)
  pendingPicks  Int      @default(0)
  totalStake    Float    @default(0)
  totalProfit   Float    @default(0)
  roi           Float    @default(0)
  yield         Float    @default(0)
  winRate       Float    @default(0)
  currentStreak Int      @default(0)
  maxStreak     Int      @default(0)
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_stats")
}
